---
export interface Props {
  name: string;
  title: string;
  tagline?: string;
}

const { name, title, tagline } = Astro.props;
---

<header class="container-wide pt-14 pb-12 sm:pt-16 sm:pb-14">
  <h1 class="text-3xl font-semibold tracking-tight text-ink sm:text-4xl dark:text-[#f5f5f7]">
    {name}
  </h1>
  <p class="mt-2 text-lg text-ink-soft dark:text-[#a1a1a6]">
    {title}
  </p>
  {tagline && (
    <p class="mt-5 max-w-2xl leading-relaxed text-ink-soft dark:text-[#a1a1a6]">
      {tagline}
    </p>
  )}
</header>
