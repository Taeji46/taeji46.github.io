---
export interface Props {
  href: string;
  title: string;
  description?: string;
  /** 外部リンクの場合 true */
  external?: boolean;
}

const { href, title, description, external = false } = Astro.props;
const rel = external ? 'noopener noreferrer' : undefined;
const target = external ? '_blank' : undefined;
---

<a
  href={href}
  target={target}
  rel={rel}
  class="group gloss gloss-link flex items-center justify-between gap-3 px-5 py-4"
>
  <span class="min-w-0">
    <span class="block font-medium text-ink dark:text-[#f5f5f7]">{title}</span>
    {description && (
      <span class="mt-0.5 block truncate text-sm text-ink-faint dark:text-[#86868b]">{description}</span>
    )}
  </span>
  <span class="shrink-0 text-ink-faint transition-all duration-300 group-hover:translate-x-0.5 group-hover:text-accent dark:text-[#86868b]">
    {external ? (
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    ) : (
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    )}
  </span>
</a>
