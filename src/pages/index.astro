          <h1 class="text-4xl font-semibold tracking-tight text-ink sm:text-5xl dark:text-[#f5f5f7]">
            {profile.name}
          </h1>
          <p class="mt-3 text-lg font-medium text-ink-soft dark:text-[#a1a1a6]">{profile.title}</p>
