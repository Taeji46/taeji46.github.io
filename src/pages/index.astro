          <ul class="space-y-4">
            {sections.map((item) => (
              <li>
                <a href={`#${item.id}`} data-nav class="side-link group flex items-center gap-3 py-1">
                  <span data-line></span>
                  <span data-label>{item.label}</span>
                </a>
              </li>
            ))}
