---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="RDFスキーマ推論規則を対象としたLLMの推論能力の評価 — 人工知能学会全国大会（第39回）"
  description="2025年度 人工知能学会全国大会（第39回）。学生奨励賞受賞。細川泰智、チャクラボルティ シュデシナ、森田武史。"
  showNav={false}
>
  <div class="mx-auto w-full max-w-2xl px-6 py-16 sm:px-8 lg:py-24">
    <nav class="mb-12">
      <a href="/" class="inline-flex items-center gap-1.5 text-sm text-ink-faint transition-colors hover:text-ink dark:text-[#86868b] dark:hover:text-white">
        ← Taichi Hosokawa
      </a>
    </nav>

    <header>
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm">
        <span class="font-medium text-ink-faint dark:text-[#86868b]">オーガナイズドセッション</span>
        <span class="font-medium text-[#b45309] dark:text-[#e0a82e]">学生奨励賞</span>
      </div>
      <p class="mt-3 font-mono text-xs text-ink-faint dark:text-[#86868b]">
        2025年度 人工知能学会全国大会（第39回） · 2025年5月
      </p>
      <h1 class="mt-4 text-2xl font-semibold leading-snug tracking-tight text-ink sm:text-3xl dark:text-[#f5f5f7]">
        RDFスキーマ推論規則を対象とした大規模言語モデルの推論能力の評価
      </h1>
      <p class="mt-4 text-sm text-ink-soft dark:text-[#a1a1a6]">細川泰智、チャクラボルティ シュデシナ、森田武史</p>
      <p class="mt-1 font-mono text-xs text-ink-faint dark:text-[#86868b]">青山学院大学 ／ 産業技術総合研究所</p>
    </header>

    <main class="mt-16 space-y-14">
      <!-- Materials -->
      <section>
        <div class="flex items-center gap-4">
          <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-ink dark:text-[#f5f5f7]">Materials</h2>
          <span class="h-px flex-1 bg-black/10 dark:bg-white/15"></span>
        </div>
        <div class="mt-4 space-y-3">
          <a
            href="https://www.jstage.jst.go.jp/article/pjsai/JSAI2025/0/JSAI2025_3P1OS46a04/_pdf/-char/ja"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-4 rounded-2xl border border-black/[0.1] px-5 py-4 transition-all duration-300 hover:border-black/[0.18] hover:bg-black/[0.02] dark:border-white/10 dark:hover:border-white/20 dark:hover:bg-white/[0.04]"
          >
            <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-accent/10 text-accent dark:bg-accent/15">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-5 w-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 3v4a1 1 0 001 1h4M9 13h6m-6 4h4m1 4H7a2 2 0 01-2-2V5a2 2 0 012-2h7l5 5v11a2 2 0 01-2 2z" />
              </svg>
            </span>
            <span class="min-w-0 flex-1">
              <span class="block font-medium text-ink dark:text-[#f5f5f7]">論文</span>
              <span class="mt-0.5 block font-mono text-xs text-ink-faint dark:text-[#86868b]">PDF</span>
            </span>
            <span class="shrink-0 text-ink-faint transition-all duration-300 group-hover:translate-x-0.5 group-hover:text-ink dark:text-[#86868b] dark:group-hover:text-white">↗</span>
          </a>
          <a
            href="https://www.jstage.jst.go.jp/article/pjsai/JSAI2025/0/JSAI2025_3P1OS46a04/_article/-char/ja/"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-4 rounded-2xl border border-black/[0.1] px-5 py-4 transition-all duration-300 hover:border-black/[0.18] hover:bg-black/[0.02] dark:border-white/10 dark:hover:border-white/20 dark:hover:bg-white/[0.04]"
          >
            <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-accent/10 text-accent dark:bg-accent/15">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-5 w-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.6 9h16.8M3.6 15h16.8M12 3a15 15 0 000 18M12 3a15 15 0 010 18M3 12a9 9 0 1018 0 9 9 0 00-18 0z" />
              </svg>
            </span>
            <span class="min-w-0 flex-1">
              <span class="block font-medium text-ink dark:text-[#f5f5f7]">J-Stage</span>
              <span class="mt-0.5 block font-mono text-xs text-ink-faint dark:text-[#86868b]">Article</span>
            </span>
            <span class="shrink-0 text-ink-faint transition-all duration-300 group-hover:translate-x-0.5 group-hover:text-ink dark:text-[#86868b] dark:group-hover:text-white">↗</span>
          </a>
        </div>
      </section>

      <!-- Contact -->
      <section>
        <div class="flex items-center gap-4">
          <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-ink dark:text-[#f5f5f7]">Contact</h2>
          <span class="h-px flex-1 bg-black/10 dark:bg-white/15"></span>
        </div>
        <dl class="mt-6 space-y-3 text-sm">
          <div class="flex gap-6">
            <dt class="w-24 shrink-0 text-ink-faint dark:text-[#86868b]">Presenter</dt>
            <dd class="text-ink dark:text-[#f5f5f7]">Taichi Hosokawa</dd>
          </div>
          <div class="flex gap-6">
            <dt class="w-24 shrink-0 text-ink-faint dark:text-[#86868b]">Email</dt>
            <dd><a href="mailto:taichi.h.agu@gmail.com" class="link-accent font-mono">taichi.h.agu@gmail.com</a></dd>
          </div>
        </dl>
      </section>
    </main>
  </div>
</BaseLayout>
